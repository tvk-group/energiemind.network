# Supabase — Partner Application Form
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_TABLE=partner_applications

# Admin Dashboard (/admin/)
ADMIN_PASSWORD=choose_a_strong_password
ADMIN_SECRET=optional_separate_signing_secret

# Setup:
# 1. Create a Supabase project
# 2. Run supabase/schema.sql in the SQL Editor
# 3. Copy keys from Settings → API
# 4. Add all vars above in Vercel → Environment Variables
# 5. Redeploy
# 6. Open https://energiemind.network/admin/

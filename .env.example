# Supabase — Partner Application Form
# Add these as Vercel Environment Variables (Production + Preview)

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_TABLE=partner_applications

# Setup:
# 1. Create a Supabase project
# 2. Run supabase/schema.sql in the SQL Editor
# 3. Copy Project URL + anon public key from Settings → API
# 4. Add env vars in Vercel → Project Settings → Environment Variables
# 5. Redeploy

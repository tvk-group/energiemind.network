# Local development — copy to .env.local (never commit .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key

# Server only (Vercel env — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ADMIN_PASSWORD=choose_a_strong_password
ADMIN_SECRET=optional_separate_signing_secret
SUPABASE_TABLE=partner_applications

# Legacy aliases (optional)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# Setup:
# 1. npm install
# 2. Copy this file to .env.local and fill in values from Supabase Dashboard → Settings → API
# 3. Run supabase/schema.sql in the SQL Editor
# 4. npm run build
# 5. Add the same variables in Vercel → Environment Variables → Redeploy
# 6. Partner form: public site | Admin: /admin/
